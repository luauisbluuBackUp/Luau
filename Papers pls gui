-- 🎨 Colors
local FRIENDLY_COLOR = Color3.fromRGB(0, 255, 0)
local ENEMY_COLOR = Color3.fromRGB(255, 0, 0)
local NEUTRAL_COLOR = Color3.fromRGB(255, 255, 0)

-- 🧠 Toggle state
local ESP_ENABLED = false

-- 🧠 Decide color
local function getRelationColor(player)
	if not LocalPlayer.Team or not player.Team then
		return NEUTRAL_COLOR
	end

	if player.Team == LocalPlayer.Team then
		return FRIENDLY_COLOR
	else
		return ENEMY_COLOR
	end
end

-- ✨ Apply ESP
local function applyESP(player, character)
	if not ESP_ENABLED then return end
	if player == LocalPlayer then return end
	if not character then return end

	-- Remove old
	local old = character:FindFirstChild("ESPHighlight")
	if old then old:Destroy() end

	local highlight = Instance.new("Highlight")
	highlight.Name = "ESPHighlight"
	highlight.FillTransparency = 0.5
	highlight.OutlineTransparency = 0

	local color = getRelationColor(player)
	highlight.FillColor = color
	highlight.OutlineColor = color

	highlight.Parent = character
end

-- ❌ Remove ESP
local function removeESP(character)
	if character and character:FindFirstChild("ESPHighlight") then
		character.ESPHighlight:Destroy()
	end
end

-- 🔁 Setup player
local function setupPlayer(player)
	if player == LocalPlayer then return end

	player.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		applyESP(player, char)
	end)

	if player.Character then
		applyESP(player, player.Character)
	end

	-- Update if THEIR team changes
	player:GetPropertyChangedSignal("Team"):Connect(function()
		if player.Character then
			if ESP_ENABLED then
				applyESP(player, player.Character)
			end
		end
	end)
end

-- 🔄 When YOUR team changes
LocalPlayer:GetPropertyChangedSignal("Team"):Connect(function()
	if not ESP_ENABLED then return end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			applyESP(player, player.Character)
		end
	end
end)

-- 🚀 Init players
for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

