		getgenv().FarmEnabled = Value

		if Value then
			-- 🔒 NEW SESSION TOKEN
			FarmToken += 1
			local myToken = FarmToken

			-- 📍 SAVE POSITION
			local char = LocalPlayer.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				SavedCFrame = char.HumanoidRootPart.CFrame
			end

			-- 🚀 START FARM
			if not FarmThread then
				FarmThread = task.spawn(function()
					StartFarm(myToken)
				end)
			end

		else
			-- 🛑 STOP EVERYTHING
			FarmToken += 1 -- instantly kills all loops
			getgenv().FarmEnabled = false

			task.wait(0.25) -- let threads exit cleanly

			-- 📍 RETURN TO SAVED POSITION
			local char = LocalPlayer.Character
			if SavedCFrame and char and char:FindFirstChild("HumanoidRootPart") then
				char.HumanoidRootPart.CFrame = SavedCFrame
			end

			FarmThread = nil
		end
	end,
})


