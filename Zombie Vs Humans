--// FLY SYSTEM
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer

local flyEnabled = false
local flyKey = Enum.KeyCode.V
local upKey = Enum.KeyCode.E

local flyConn
local inputConn
local upHeld = false

local function setupFly(char)
    local humanoid = char:WaitForChild("Humanoid")
    local root = char:WaitForChild("HumanoidRootPart")

    -- CLEAN OLD CONNECTIONS
    if flyConn then flyConn:Disconnect() end
    if inputConn then inputConn:Disconnect() end

    -- INPUT
    inputConn = UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end

        if input.KeyCode == flyKey then
            flyEnabled = not flyEnabled
        end

        if input.KeyCode == upKey then
            upHeld = true
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == upKey then
            upHeld = false
        end
    end)

    -- FLY LOOP
    flyConn = RunService.Heartbeat:Connect(function()
        if not flyEnabled then return end

        local moveDir = root.CFrame.LookVector

        local velocity = Vector3.zero

        -- forward movement (based on camera look)
        if humanoid.MoveDirection.Magnitude > 0 then
            velocity = humanoid.MoveDirection * 50
        end

        -- upward movement
        if upHeld then
            velocity = velocity + Vector3.new(0, 50, 0)
        end

        local bv = Instance.new("BodyVelocity")
        bv.Velocity = velocity
        bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bv.Parent = root

        game:GetService("Debris"):AddItem(bv, 0.1)
    end)
end

--// RESPAWN SAFE
player.CharacterAdded:Connect(setupFly)
if player.Character then
    setupFly(player.Character)
end

MoveTab:CreateToggle({
   Name = "Fly Mode",
   CurrentValue = false,
   Callback = function(Value)
      flyEnabled = Value
   end
})

MoveTab:CreateInput({
   Name = "Fly Toggle Key (single letter)",
   PlaceholderText = "V",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local key = Text:upper():sub(1,1)
      local success, enumKey = pcall(function()
          return Enum.KeyCode[key]
      end)

      if success and enumKey then
          flyKey = enumKey
      end
   end
})
