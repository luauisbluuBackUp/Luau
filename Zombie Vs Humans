local Players = game:GetService("Players")
local player = Players.LocalPlayer

--// SETTINGS
local isEnabled = false
local currentSize = 10
local currentTrans = 0.5

--// TEAM CHECK
local function isEnemy(otherPlayer)
    if not otherPlayer.Team or not player.Team then
        return true
    end
    return otherPlayer.Team ~= player.Team
end

--// APPLY HITBOX (single target only)
local function applyHitbox(char, owner)
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if isEnabled and isEnemy(owner) then
        root.Size = Vector3.new(currentSize, currentSize, currentSize)
        root.Transparency = currentTrans
    else
        root.Size = Vector3.new(2, 2, 1)
        root.Transparency = 1
    end

    root.CanCollide = false
end

--// APPLY ONLY ONE PLAYER
local function refreshPlayer(p)
    if p == player then return end
    if p.Character then
        applyHitbox(p.Character, p)
    end
end

--// HOOK PLAYER (RESPAWN SAFE)
local function hookPlayer(p)
    if p == player then return end

    -- initial spawn
    if p.Character then
        task.spawn(function()
            refreshPlayer(p)
        end)
    end

    -- respawn ONLY THIS PLAYER
    p.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        applyHitbox(char, p)
    end)
end

--// SETUP ALL PLAYERS
for _, p in ipairs(Players:GetPlayers()) do
    hookPlayer(p)
end

Players.PlayerAdded:Connect(hookPlayer)

