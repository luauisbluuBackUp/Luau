------------------------------------------------
--// ANTI FALL SYSTEM (PHYSICS BASED)
------------------------------------------------
local function setupAntiFall(char)
    local root = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:WaitForChild("Humanoid")

    if antiFallConn then
        antiFallConn:Disconnect()
        antiFallConn = nil
    end

    antiFallConn = RunService.Heartbeat:Connect(function()
        if not getgenv().AntiFallEnabled then return end
        if not root or not humanoid then return end

        local vel = root.AssemblyLinearVelocity

        -- 🪂 detect dangerous fall speed
        if vel.Y < -50 then
            -- soften fall instead of letting damage threshold hit
            root.AssemblyLinearVelocity = Vector3.new(
                vel.X,
                -10, -- controlled descent
                vel.Z
            )
        end
    end)
end

