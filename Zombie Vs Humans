local EspTab = Window:CreateTab("ESP", 4483362458)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

local espEnabled = false
local espCache = {} -- [player] = Highlight

--// COLOR LOGIC
local function getColor(p)
    if not p.Team or not player.Team then
        return Color3.fromRGB(255, 60, 60)
    end

    return (p.Team == player.Team)
        and Color3.fromRGB(0, 170, 255)
        or Color3.fromRGB(255, 60, 60)
end

--// CREATE / REFRESH ESP
local function applyESP(p)
    if p == player then return end
    if not espEnabled then return end

    local char = p.Character
    if not char then return end

    -- wait for proper spawn
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- remove old highlight (NO duplicates allowed)
    if espCache[p] then
        espCache[p]:Destroy()
        espCache[p] = nil
    end

    local hl = Instance.new("Highlight")
    hl.Name = "ESP_Highlight"
    hl.Adornee = char
    hl.FillTransparency = 0.5
    hl.OutlineTransparency = 0
    hl.FillColor = getColor(p)

    hl.Parent = char
    espCache[p] = hl
end

--// REMOVE ESP
local function removeESP(p)
    if espCache[p] then
        espCache[p]:Destroy()
        espCache[p] = nil
    end
end

--// SAFE PLAYER HOOK
local function hookPlayer(p)
    if p == player then return end

    -- 👤 when character spawns (RESPAWN SAFE)
    p.CharacterAdded:Connect(function(char)
        -- wait for full load (important fix)
        task.wait(0.2)

        if espEnabled then
            applyESP(p)
        end
    end)

    -- 👤 if already spawned
    if p.Character then
        task.spawn(function()
            task.wait(0.2)
            if espEnabled then
                applyESP(p)
            end
        end)
    end
end

--// INITIAL SETUP
for _, p in ipairs(Players:GetPlayers()) do
    hookPlayer(p)
end

Players.PlayerAdded:Connect(function(p)
    hookPlayer(p)

    -- immediate respawn-safe apply
    p.CharacterAdded:Connect(function()
        task.wait(0.2)
        if espEnabled then
