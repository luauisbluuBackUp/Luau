local Main = Window:CreateTab("main", 4483362458) -- Title, Image

local Section = Main:CreateSection("ESP")

local ActiveZombies = workspace:WaitForChild("ActiveZombies")

local EnabledTypes = {}
local ESPObjects = {}

local Colors = {
	Brawler = Color3.fromRGB(255, 0, 0),
	Bloodletter = Color3.fromRGB(150, 0, 0),
	Bloomer = Color3.fromRGB(255, 100, 0),
	Shambler = Color3.fromRGB(0, 255, 0),
	Sniveler = Color3.fromRGB(0, 150, 255),
	VariantShambler = Color3.fromRGB(200, 0, 255),
	Butcher = Color3.fromRGB(255, 255, 0)
}

local function AddESP(zombie)
	if ESPObjects[zombie] then return end
	if not EnabledTypes[zombie.Name] then return end

	local highlight = Instance.new("Highlight")
	highlight.Name = "ZombieESP"
	highlight.FillColor = Colors[zombie.Name] or Color3.new(1,1,1)
	highlight.OutlineColor = Color3.fromRGB(255,255,255)
	highlight.FillTransparency = 0.5
	highlight.Parent = zombie

	ESPObjects[zombie] = highlight
end

local function RemoveESP(zombie)
	if ESPObjects[zombie] then
		ESPObjects[zombie]:Destroy()
		ESPObjects[zombie] = nil
	end
end

local function RefreshESP()
	for _, zombie in ipairs(ActiveZombies:GetChildren()) do
		RemoveESP(zombie)
		AddESP(zombie)
	end
end

ActiveZombies.ChildAdded:Connect(function(zombie)
	AddESP(zombie)
end)

ActiveZombies.ChildRemoved:Connect(function(zombie)
	RemoveESP(zombie)
end)

